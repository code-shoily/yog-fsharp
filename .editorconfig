# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All files
[*]
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# F# files
[*.fs]
indent_size = 4
max_line_length = 120

# F# project files
[*.fsproj]
indent_size = 4

# JSON files
[*.json]
indent_size = 2

# XML files
[*.{xml,props,targets}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Ignore generated files
[{bin,obj}/**]
generated_code = true
